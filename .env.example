# SentinelNode — .env.example
#
# Copy this file to .env and fill in your own values.
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_random_64_char_hex_string
JWT_REFRESH_SECRET=change_me_to_a_different_random_64_char_hex_string

# ── Scan target ───────────────────────────────────────────────────────────────
# Absolute path to the local directory you want to scan.
# Windows + WSL example: SCAN_PATH=/mnt/c/Users/Beetlejuice/Desktop
# Linux / Mac example:   SCAN_PATH=/home/youruser/projects
SCAN_PATH=/absolute/path/to/scan

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
